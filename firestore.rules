// ==========================================
// 🔒 Firestore Security Rules — Route Planner
// วิธีใช้: Firebase Console → Firestore → Rules → วางโค้ดนี้ → Publish
//
// โครงสร้าง Collections:
//   appData/{centerId}_main                         ← metadata ของแต่ละศูนย์
//   appData/{centerId}_main/routes/{r}              ← metadata สายวิ่ง (ChunkDB format)
//   appData/{centerId}_main/routes/{r}/chunks/{c}  ← ข้อมูลร้านค้า แบ่ง 200 ร้าน/chunk
//   appData/app_users                               ← users ทั้งหมด
//   appData/app_centers                             ← รายการศูนย์
//   v1_raw_chunks/{chunkId}                         ← ข้อมูลการขายดิบ
//   v1_sales_chunks/{chunkId}                       ← KPI ที่ประมวลผลแล้ว
//   sellout/{year_month}                            ← Dashboard: Sellout metadata รายเดือน
//   sellout/{year_month}/chunks/{chunkId}           ← Dashboard: Sellout rows แบ่ง chunk
//   targets/{year_month}                            ← Dashboard: Target รายสายรายเดือน
//   routes/{routeName}                              ← ChunkDB routes (firebase-chunks.js)
//   routes/{routeName}/chunks/{chunkId}             ← ChunkDB route chunks
// ==========================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ❌ ปิดทุกอย่างเป็น default (deny-by-default)
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // 👥 app_users
    // ==========================================
    match /appData/app_users {
      allow read: if true;
      allow write: if request.resource.data.keys().hasAll(['users'])
                   && request.resource.data.users is list
                   && request.resource.data.users.size() > 0;
    }

    // ==========================================
    // 🏢 app_centers
    // ==========================================
    match /appData/app_centers {
      allow read: if true;
      allow write: if request.resource.data.keys().hasAll(['centers'])
                   && request.resource.data.centers is map;
    }

    // ==========================================
    // 📋 appData/{centerDoc} — metadata ศูนย์
    // ==========================================
    match /appData/{centerDoc} {
      allow read: if centerDoc.matches('[0-9a-zA-Z_]+_main')
                  || centerDoc == 'v1_main';
      allow write: if (centerDoc.matches('[0-9a-zA-Z_]+_main') || centerDoc == 'v1_main')
                   && validCenterDoc(request.resource.data);

      // 📝 drafts/{YYYY_MM} — Draft plan รายเดือน
      match /drafts/{yearMonth} {
        allow read: if true;
        allow delete: if true;
        allow write: if validYearMonth(yearMonth)
                     && request.resource.data is map
                     && request.resource.data.keys().hasAny(['routeList','cycleDays','calendarConfig','updatedAt','createdAt','sourceMode']);

        match /routes/{routeId} {
          allow read: if true;
          allow delete: if true;
          allow write: if request.resource.data.keys().hasAll(['stores'])
                       && request.resource.data.stores is list
                       && request.resource.data.stores.size() <= 2000;
        }
      }

      // 🔒 history/{YYYY_MM} — Snapshot plan ที่ activate แล้ว
      match /history/{yearMonth} {
        allow read: if true;
        allow delete: if true;
        allow write: if validYearMonth(yearMonth)
                     && request.resource.data is map;

        match /routes/{routeId} {
          allow read: if true;
          allow delete: if true;
          allow write: if request.resource.data.keys().hasAll(['stores'])
                       && request.resource.data.stores is list
                       && request.resource.data.stores.size() <= 2000;
        }
      }

      // 🛣️ routes/{routeId} — metadata ของแต่ละสาย
      match /routes/{routeId} {
        allow read: if true;
        allow delete: if true;
        allow write: if (request.resource.data.keys().hasAll(['stores'])
                         && request.resource.data.stores is list
                         && request.resource.data.stores.size() <= 500)
                     ||
                     (request.resource.data.keys().hasAny(['totalStores', 'totalChunks', 'version']));

        // 📦 chunks/{chunkId} — ข้อมูลร้านค้าจริง
        match /chunks/{chunkId} {
          allow read: if true;
          allow delete: if true;
          allow write: if request.resource.data.keys().hasAll(['index', 'stores'])
                       && request.resource.data.index is number
                       && request.resource.data.stores is list
                       && request.resource.data.stores.size() <= 250;
        }
      }
    }

    // ==========================================
    // 📊 v1_raw_chunks — ข้อมูลการขายดิบ
    // ==========================================
    match /v1_raw_chunks/{chunkId} {
      allow read: if true;
      allow delete: if true;
      allow write: if request.resource.data.keys().hasAll(['rows'])
                   && request.resource.data.rows is list
                   && request.resource.data.rows.size() <= 550;
    }

    // ==========================================
    // 🎯 v1_sales_chunks — KPI ที่ประมวลผลแล้ว
    // ==========================================
    match /v1_sales_chunks/{chunkId} {
      allow read: if true;
      allow delete: if true;
      allow write: if request.resource.data is map;
    }

    // ==========================================
    // 📈 ChunkDB routes (firebase-chunks.js)
    // collection('routes').doc(routeName)
    // ==========================================
    match /routes/{routeName} {
      allow read: if true;
      allow delete: if true;
      allow write: if request.resource.data is map;

      match /chunks/{chunkId} {
        allow read: if true;
        allow delete: if true;
        allow write: if request.resource.data.keys().hasAll(['index', 'stores'])
                     && request.resource.data.index is number
                     && request.resource.data.stores is list;
      }
    }

    // ==========================================
    // 📊 sellout — Dashboard Sellout รายเดือน
    // sellout/{YYYY_MM}              ← metadata (totalRows, updatedAt, version)
    // sellout/{YYYY_MM}/chunks/{c}  ← rows จริง แบ่ง 300 rows/chunk
    // ==========================================
    match /sellout/{yearMonth} {
      allow read: if true;
      allow write: if validYearMonth(yearMonth)
                   && request.resource.data.keys().hasAny(['totalRows', 'updatedAt', 'version']);
      allow delete: if true;

      match /chunks/{chunkId} {
        allow read: if true;
        allow delete: if true;
        allow write: if request.resource.data.keys().hasAll(['index', 'rows'])
                     && request.resource.data.index is number
                     && request.resource.data.rows is list
                     && request.resource.data.rows.size() <= 350;
      }
    }

    // ==========================================
    // 🎯 targets — Target รายสายรายเดือน
    // targets/{YYYY_MM} ← { routes: { "402V01": 500000, ... }, updatedAt }
    // ==========================================
    match /targets/{yearMonth} {
      allow read: if true;
      allow write: if validYearMonth(yearMonth)
                   && request.resource.data.keys().hasAny(['routes', 'updatedAt'])
                   && (!request.resource.data.keys().hasAll(['routes'])
                       || request.resource.data.routes is map);
      allow delete: if true;
    }

  }

  // ==========================================
  // 🔧 Helper Functions
  // ==========================================

  function validCenterDoc(data) {
    return data.keys().hasAny(['routeList', 'cycleDays', 'routes', 'kpiSettings', 'savedRawColumns', 'createdAt',
                                'draftList', 'historyList', 'lastActivated', 'updatedAt'])
           && (!data.keys().hasAll(['routeList']) || data.routeList is list)
           && (!data.keys().hasAll(['cycleDays']) || data.cycleDays is number)
           && (!data.keys().hasAll(['draftList']) || data.draftList is list)
           && (!data.keys().hasAll(['historyList']) || data.historyList is list);
  }

  // ตรวจรูปแบบ YYYY_MM เช่น 2026_04
  function validYearMonth(ym) {
    return ym.matches('[0-9]{4}_[0-9]{2}');
  }

}
