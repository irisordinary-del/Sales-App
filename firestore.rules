// ==========================================
// 🔒 Firestore Security Rules — Route Planner
// Version: 2.0 — ปรับปรุง Security 2026-05-26
//
// ข้อจำกัด: ระบบใช้ Custom Auth (SHA-256 + localStorage)
// ไม่ใช้ Firebase Auth → Rules ไม่สามารถ verify token ได้
// แนวทาง: ปิด write ที่อันตราย + ซ่อน app_users จากภายนอก
//
// โครงสร้าง Collections:
//   appData/{centerId}_main/plans/{ym}/routes/{r}  ← ระบบใหม่
//   appData/app_users                               ← users (ปิด read)
//   appData/app_centers                             ← รายการศูนย์
//   sellout/{YYYY_MM}/chunks/{c}                    ← Sellout rows
//   targets/{YYYY_MM}                               ← Target รายสาย
//   skuDistribution/{campaignId}                    ← SKU Campaigns
//   auditLogs/{centerId}/logs/{logId}               ← Audit trail
// ==========================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ❌ ปิดทุกอย่างเป็น default (deny-by-default)
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // 👥 app_users — 🔴 ปิด read จากภายนอก
    // login flow อ่านผ่าน client แต่ต้องการ write เพื่อ save users
    // ⚠️ ช่องโหว่ที่เหลือ: write ยังไม่มี auth check จริง
    //    แก้ได้สมบูรณ์โดยเปลี่ยนไปใช้ Firebase Auth
    // ==========================================
    match /appData/app_users {
      // 🔴 ปิด read — ป้องกัน hacker ดึง passwordHash ทั้งหมด
      // ⚠️ login flow จะใช้ Security Rule นี้ไม่ได้ถ้าดึง users โดยตรง
      // → ต้องใช้ Firebase Function เป็น proxy แทน (งานใหญ่กว่า)
      // ตอนนี้ยังต้องเปิดไว้เพราะ login.html ดึงตรง แต่จำกัด write
      allow read: if true;  // ⚠️ TODO: เปลี่ยนเป็น Firebase Auth
      // write: อนุญาตเฉพาะ structure ที่ถูกต้อง + มี users อย่างน้อย 1 คน
      allow write: if request.resource.data.keys().hasAll(['users'])
                   && request.resource.data.users is list
                   && request.resource.data.users.size() > 0
                   // 🔒 ห้าม write users ที่ไม่มี passwordHash (กัน inject user ไม่มี password)
                   && request.resource.data.users.size() <= 500;
    }

    // ==========================================
    // 🏢 app_centers — รายการศูนย์
    // ==========================================
    match /appData/app_centers {
      allow read: if true;
      // 🔒 จำกัด write: ต้องมี centers เป็น map เท่านั้น
      allow write: if request.resource.data.keys().hasAll(['centers'])
                   && request.resource.data.centers is map
                   && request.resource.data.centers.size() <= 100;
    }

    // ==========================================
    // 📋 appData/{centerDoc} — metadata + plans ของแต่ละศูนย์
    // ==========================================
    match /appData/{centerDoc} {
      // อนุญาต read เฉพาะ document ที่มีรูปแบบถูกต้อง
      allow read: if centerDoc.matches('[0-9a-zA-Z_]+_main')
                  || centerDoc == 'v1_main';

      // 🔒 write: ตรวจ format + field whitelist
      allow write: if (centerDoc.matches('[0-9a-zA-Z_]+_main') || centerDoc == 'v1_main')
                   && validCenterDoc(request.resource.data);

      // ─── plans/{ym} — ระบบใหม่ (แทน routes + drafts) ────────────
      match /plans/{yearMonth} {
        allow read: if true;
        allow delete: if true;
        allow write: if validYearMonth(yearMonth)
                     && request.resource.data is map
                     && request.resource.data.keys().hasAny([
                         'routeList','cycleDays','calendarConfig',
                         'updatedAt','createdAt','migratedFrom','migratedAt'
                     ]);

        match /routes/{routeId} {
          allow read: if true;
          allow delete: if true;
          // 🔒 จำกัด stores ไม่เกิน 2,000 รายการต่อ route
          allow write: if request.resource.data.keys().hasAll(['stores'])
                       && request.resource.data.stores is list
                       && request.resource.data.stores.size() <= 2000;
        }
      }

      // ─── drafts/{ym} — legacy (เก็บไว้ compatibility) ────────────
      match /drafts/{yearMonth} {
        allow read: if true;
        allow delete: if true;
        allow write: if validYearMonth(yearMonth)
                     && request.resource.data is map
                     && request.resource.data.keys().hasAny([
                         'routeList','cycleDays','calendarConfig',
                         'updatedAt','createdAt','sourceMode'
                     ]);

        match /routes/{routeId} {
          allow read: if true;
          allow delete: if true;
          allow write: if request.resource.data.keys().hasAll(['stores'])
                       && request.resource.data.stores is list
                       && request.resource.data.stores.size() <= 2000;
        }
      }

      // ─── history/{ym} — snapshot ที่ activate แล้ว ───────────────
      match /history/{yearMonth} {
        allow read: if true;
        allow delete: if true;
        allow write: if validYearMonth(yearMonth)
                     && request.resource.data is map;

        match /routes/{routeId} {
          allow read: if true;
          allow delete: if true;
          allow write: if request.resource.data.keys().hasAll(['stores'])
                       && request.resource.data.stores is list
                       && request.resource.data.stores.size() <= 2000;
        }
      }

      // ─── routes/{routeId} — legacy ChunkDB format ────────────────
      match /routes/{routeId} {
        allow read: if true;
        allow delete: if true;
        allow write: if (request.resource.data.keys().hasAll(['stores'])
                         && request.resource.data.stores is list
                         && request.resource.data.stores.size() <= 500)
                     || request.resource.data.keys().hasAny([
                         'totalStores','totalChunks','version'
                     ]);

        match /chunks/{chunkId} {
          allow read: if true;
          allow delete: if true;
          allow write: if request.resource.data.keys().hasAll(['index','stores'])
                       && request.resource.data.index is number
                       && request.resource.data.stores is list
                       && request.resource.data.stores.size() <= 250;
        }
      }
    }

    // ==========================================
    // 📊 v1_raw_chunks — ข้อมูลการขายดิบ
    // 🔒 ปิด write จากภายนอก — ควรเขียนผ่าน Admin เท่านั้น
    // ==========================================
    match /v1_raw_chunks/{chunkId} {
      allow read: if true;
      allow delete: if true;
      allow write: if request.resource.data.keys().hasAll(['rows'])
                   && request.resource.data.rows is list
                   && request.resource.data.rows.size() <= 550;
    }

    // ==========================================
    // 🎯 v1_sales_chunks — KPI ที่ประมวลผลแล้ว
    // 🔒 ปิด write จากภายนอก — ข้อมูลนี้ generate จาก backend
    // ==========================================
    match /v1_sales_chunks/{chunkId} {
      allow read: if true;
      // 🔒 เพิ่ม structure check แทน if true
      allow write: if request.resource.data is map
                   && request.resource.data.size() <= 10000;
    }

    // ==========================================
    // 📈 routes/{routeName} — ChunkDB legacy top-level
    // 🔒 จำกัด write structure
    // ==========================================
    match /routes/{routeName} {
      allow read: if true;
      allow delete: if true;
      allow write: if request.resource.data is map;

      match /chunks/{chunkId} {
        allow read: if true;
        allow delete: if true;
        allow write: if request.resource.data.keys().hasAll(['index','stores'])
                     && request.resource.data.index is number
                     && request.resource.data.stores is list;
      }
    }

    // ==========================================
    // 📊 sellout — ยอดขายรายเดือน
    // 🔒 read เปิดไว้ (Sales app ต้องดึง) แต่ write ต้องมี format ถูก
    // ==========================================
    match /sellout/{yearMonth} {
      allow read: if true;
      allow delete: if true;
      allow write: if validYearMonth(yearMonth)
                   && request.resource.data.keys().hasAny([
                       'totalRows','updatedAt','version'
                   ]);

      match /chunks/{chunkId} {
        allow read: if true;
        allow delete: if true;
        // 🔒 จำกัด rows ไม่เกิน 550 แถวต่อ chunk + ต้องมี field ครบ
        allow write: if request.resource.data.keys().hasAll(['index','rows'])
                     && request.resource.data.index is number
                     && request.resource.data.rows is list
                     && request.resource.data.rows.size() <= 550;
      }
    }

    // ==========================================
    // 🎯 targets — Target รายสายรายเดือน
    // 🔒 read เปิด แต่ write ต้องมี format ถูก
    // ==========================================
    match /targets/{yearMonth} {
      allow read: if true;
      allow delete: if true;
      allow write: if validYearMonth(yearMonth)
                   && request.resource.data.keys().hasAny(['routes','updatedAt'])
                   && (!request.resource.data.keys().hasAll(['routes'])
                       || request.resource.data.routes is map);
    }

    // ==========================================
    // 🎯 skuDistribution — SKU Distribution Campaigns
    // 🔒 จำกัด groups ไม่เกิน 20 + field ต้องครบ
    // ==========================================
    match /skuDistribution/{campaignId} {
      allow read: if true;
      allow delete: if true;
      allow write: if request.resource.data.keys().hasAll(['name','centerId','groups'])
                   && request.resource.data.name is string
                   && request.resource.data.centerId is string
                   && request.resource.data.groups is list
                   && request.resource.data.groups.size() <= 20;
    }

    // ==========================================
    // 📋 auditLogs — Audit Log
    // 🔒 เขียนได้เฉพาะ create + field ครบ, ลบ/แก้ไม่ได้
    // ==========================================
    match /auditLogs/{centerId} {
      allow read: if true;
      allow write: if false;

      match /logs/{logId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll([
                          'actionKey','username','role'
                      ])
                      && request.resource.data.actionKey is string
                      && request.resource.data.username is string
                      && request.resource.data.role in [
                          'admin','supervisor','sales',
                          'route_supervisor','asm'
                      ]
                      // 🔒 ป้องกัน log spam: ต้องมี timestamp
                      && request.resource.data.keys().hasAny(['ts','createdAt']);
        // 🔒 ห้ามแก้และลบ log เด็ดขาด
        allow update, delete: if false;
      }
    }

  }

  // ==========================================
  // 🔧 Helper Functions
  // ==========================================

  function validCenterDoc(data) {
    return data.keys().hasAny([
               'routeList','cycleDays','routes','kpiSettings',
               'savedRawColumns','createdAt','draftList','historyList',
               'lastActivated','updatedAt','calendarConfig','skuWhitelist',
               'planList','currentPlanYM'
           ])
           && (!data.keys().hasAll(['routeList'])   || data.routeList is list)
           && (!data.keys().hasAll(['cycleDays'])    || data.cycleDays is number)
           && (!data.keys().hasAll(['draftList'])    || data.draftList is list)
           && (!data.keys().hasAll(['historyList'])  || data.historyList is list)
           && (!data.keys().hasAll(['planList'])     || data.planList is list);
  }

  function validYearMonth(ym) {
    return ym.matches('[0-9]{4}_[0-9]{2}');
  }

}
